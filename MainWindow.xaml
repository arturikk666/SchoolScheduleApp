<Window x:Class="_111.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Школьное расписание - Оперативные замены" 
        WindowState="Maximized"
        FontSize="14"
        Background="#1A1A1A"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Стиль для кнопок навигации (темный) -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0 5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15 0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E1E1E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для активной кнопки -->
        <Style x:Key="ActiveNavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1988E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для заголовков DataGrid (темный) -->
        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#005A9E"/>
            <Setter Property="BorderThickness" Value="0 0 1 0"/>
        </Style>

        <!-- Стиль для ячеек DataGrid (темный) -->
        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0 0 1 0"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3B5A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для строк DataGrid (темный) -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0 0 0 1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3B5A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель навигации (темная) -->
        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="0 20 20 0" Margin="0 0 5 0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <!-- Логотип школы -->
                    <Border Background="#0078D4" CornerRadius="10" Padding="15" Margin="0 0 0 25">
                        <TextBlock Text="ШКОЛЬНОЕ РАСПИСАНИЕ" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </Border>

                    <!-- Основные разделы -->
                    <TextBlock Text="ОСНОВНЫЕ РАЗДЕЛЫ" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="#808080" 
                               Margin="0 0 0 10"/>

                    <Button x:Name="BtnTeachers" Content="👥 Учителя" 
                            Style="{StaticResource NavButtonStyle}" 
                            Click="BtnTeachers_Click"/>

                    <Button x:Name="BtnClasses" Content="🏫 Классы" 
                            Style="{StaticResource NavButtonStyle}" 
                            Click="BtnClasses_Click"/>

                    <Button x:Name="BtnSchedule" Content="📅 Расписание" 
                            Style="{StaticResource NavButtonStyle}" 
                            Click="BtnSchedule_Click"/>

                    <Button x:Name="BtnAbsences" Content="🚫 Отсутствия" 
                            Style="{StaticResource NavButtonStyle}" 
                            Click="BtnAbsences_Click"/>

                    <Button x:Name="BtnReplacements" Content="🔄 Замены" 
                            Style="{StaticResource NavButtonStyle}" 
                            Click="BtnReplacements_Click"/>

                    <Border Height="1" Background="#333333" Margin="0 20"/>

                    <!-- Операции -->
                    <TextBlock Text="ОПЕРАЦИИ" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="#808080" 
                               Margin="0 0 0 10"/>

                    <Button x:Name="BtnAdd" Content="➕ Добавить запись" 
                            Style="{StaticResource NavButtonStyle}" 
                            Background="#107C10"
                            Foreground="White"
                            Click="BtnAdd_Click"/>

                    <Button x:Name="BtnEdit" Content="✏️ Редактировать" 
                            Style="{StaticResource NavButtonStyle}" 
                            Background="#8A6E3B"
                            Foreground="White"
                            Click="BtnEdit_Click"/>

                    <Button x:Name="BtnDelete" Content="🗑️ Удалить" 
                            Style="{StaticResource NavButtonStyle}" 
                            Background="#A4262C"
                            Foreground="White"
                            Click="BtnDelete_Click"/>

                    <Border Height="1" Background="#333333" Margin="0 20"/>

                    <!-- Информация о пользователе -->
                    <StackPanel Margin="0 10">
                        <TextBlock Text="Пользователь:" 
                                   Foreground="#808080" 
                                   FontSize="12"/>
                        <TextBlock x:Name="CurrentUserInfo" 
                                   Text="Завуч" 
                                   Foreground="White" 
                                   FontWeight="Bold" 
                                   FontSize="14"/>
                        <TextBlock Text="МОБУ СОШ №1 им. М. Абдуллина" 
                                   Foreground="#808080" 
                                   FontSize="11"
                                   Margin="0 5 0 0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Основная рабочая область (темная) -->
        <Border Grid.Column="1" Background="#2D2D2D" CornerRadius="20" Padding="20" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок и статистика -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 15">
                    <TextBlock x:Name="TitleText" 
                               Text="Учителя" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="White"
                               Margin="0 0 20 0"/>

                    <Border Background="#3D3D3D" CornerRadius="15" Padding="8 3 8 3" VerticalAlignment="Center">
                        <TextBlock x:Name="CountText" 
                                   Text="Всего записей: 0" 
                                   Foreground="#0078D4" 
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <!-- Таблицы данных -->
                <Grid Grid.Row="1">
                    <!-- Таблица учителей (Teachers) -->
                    <DataGrid x:Name="TeachersGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Visibility="Visible"
                              Background="#2D2D2D"
                              BorderBrush="#444444"
                              BorderThickness="1"
                              GridLinesVisibility="None"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              RowStyle="{StaticResource {x:Type DataGridRow}}"
                              SelectionUnit="FullRow"
                              SelectionMode="Single"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="250"/>
                            <DataGridTextColumn Header="Предмет" Binding="{Binding Subject}" Width="200"/>
                            <DataGridTextColumn Header="Ставка" Binding="{Binding EmploymentRate}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Таблица классов (Classes) -->
                    <DataGrid x:Name="ClassesGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Visibility="Collapsed"
                              Background="#2D2D2D"
                              BorderBrush="#444444"
                              BorderThickness="1"
                              GridLinesVisibility="None"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              RowStyle="{StaticResource {x:Type DataGridRow}}"
                              SelectionUnit="FullRow"
                              SelectionMode="Single"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Название класса" Binding="{Binding ClassName}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Таблица расписания (Schedule) -->
                    <DataGrid x:Name="ScheduleGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Visibility="Collapsed"
                              Background="#2D2D2D"
                              BorderBrush="#444444"
                              BorderThickness="1"
                              GridLinesVisibility="None"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              RowStyle="{StaticResource {x:Type DataGridRow}}"
                              SelectionUnit="FullRow"
                              SelectionMode="Single"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Класс" Binding="{Binding ClassName}" Width="80"/>
                            <DataGridTextColumn Header="Предмет" Binding="{Binding Subject}" Width="150"/>
                            <DataGridTextColumn Header="Учитель" Binding="{Binding TeacherName}" Width="200"/>
                            <DataGridTextColumn Header="День" Binding="{Binding DayOfWeek}" Width="80"/>
                            <DataGridTextColumn Header="Урок" Binding="{Binding LessonNumber}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Таблица отсутствий (Absences) -->
                    <DataGrid x:Name="AbsencesGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Visibility="Collapsed"
                              Background="#2D2D2D"
                              BorderBrush="#444444"
                              BorderThickness="1"
                              GridLinesVisibility="None"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              RowStyle="{StaticResource {x:Type DataGridRow}}"
                              SelectionUnit="FullRow"
                              SelectionMode="Single"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Учитель" Binding="{Binding TeacherName}" Width="200"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding AbsenceDate, StringFormat='dd.MM.yyyy'}" Width="100"/>
                            <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="300"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Таблица замен (Replacements) -->
                    <DataGrid x:Name="ReplacementsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Visibility="Collapsed"
                              Background="#2D2D2D"
                              BorderBrush="#444444"
                              BorderThickness="1"
                              GridLinesVisibility="None"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              RowStyle="{StaticResource {x:Type DataGridRow}}"
                              SelectionUnit="FullRow"
                              SelectionMode="Single"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Отсутствующий" Binding="{Binding AbsentTeacher}" Width="200"/>
                            <DataGridTextColumn Header="Замещающий" Binding="{Binding SubstituteTeacher}" Width="200"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>